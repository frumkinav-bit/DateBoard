@page
@model DateBoard.Pages.Feed.IndexModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = "Лента";
    var currentUser = await UserManager.GetUserAsync(User);
}
 
<style>
    .feed-page {
        background: linear-gradient(180deg, #FFF5F7 0%, #F8F9FA 100%);
        min-height: 100vh;
        padding: 20px;
        padding-bottom: 100px;
    }
 
    /* Центрированные фильтры */
    .filters-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 24px;
    }
 
    .filters-bar {
        background: white;
        border-radius: 24px;
        padding: 24px 32px;
        box-shadow: 0 8px 32px rgba(255,88,88,0.12);
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: end;
        max-width: 900px;
        width: 100%;
        border: 1px solid #FFE8E8;
    }
 
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
        min-width: 140px;
    }
 
    .filter-group label {
        font-size: 11px;
        font-weight: 700;
        color: #FF5858;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }
 
    .filter-input {
        background: #F8F9FA;
        border: 2px solid transparent;
        border-radius: 16px;
        padding: 14px 18px;
        font-size: 14px;
        font-weight: 500;
        color: #2D3436;
        transition: all 0.2s;
        font-family: 'Montserrat', sans-serif;
    }
 
    .filter-input:focus {
        outline: none;
        border-color: #FF5858;
        background: white;
    }
 
    /* Кастомный dropdown */
    .custom-dropdown-wrapper {
        position: relative;
    }
 
    .custom-dropdown-trigger {
        background: #F8F9FA;
        border: 2px solid transparent;
        border-radius: 16px;
        padding: 14px 40px 14px 18px;
        font-size: 14px;
        font-weight: 500;
        color: #2D3436;
        cursor: pointer;
        transition: all 0.2s;
        font-family: 'Montserrat', sans-serif;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
    }
 
    .custom-dropdown-trigger:hover,
    .custom-dropdown-wrapper.active .custom-dropdown-trigger {
        border-color: #FF5858;
        background: white;
    }
 
    .dropdown-arrow {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        transition: transform 0.3s ease;
        pointer-events: none;
    }
 
    .custom-dropdown-wrapper.active .dropdown-arrow {
        transform: translateY(-50%) rotate(180deg);
    }
 
    .custom-dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        right: 0;
        background: white;
        border-radius: 16px;
        box-shadow: 0 16px 48px rgba(255,88,88,0.15);
        z-index: 1000;
        overflow: hidden;
        border: 1px solid #FFE8E8;
        animation: dropdownFade 0.2s ease;
    }
 
    @@keyframes dropdownFade {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
 
    .custom-dropdown-wrapper.active .custom-dropdown-menu {
        display: block;
    }
 
    .custom-dropdown-item {
        padding: 14px 18px;
        font-size: 14px;
        font-weight: 500;
        color: #636E72;
        cursor: pointer;
        transition: all 0.15s;
        font-family: 'Montserrat', sans-serif;
        border-bottom: 1px solid #FFF5F5;
    }
 
    .custom-dropdown-item:last-child {
        border-bottom: none;
    }
 
    .custom-dropdown-item:hover {
        background: rgba(255,88,88,0.05);
        color: #FF5858;
    }
 
    .custom-dropdown-item.selected {
        color: #FF5858;
        font-weight: 600;
        background: linear-gradient(90deg, #FFF5F7 0%, white 100%);
    }
 
    .filter-btn {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        color: white;
        border: none;
        border-radius: 50px;
        padding: 14px 32px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        font-family: 'Montserrat', sans-serif;
        box-shadow: 0 8px 24px rgba(255,88,88,0.3);
    }
 
    .filter-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(255,88,88,0.4);
    }
 
    .filter-reset {
        background: #FFF5F7;
        color: #FF5858;
        border: 2px solid #FFE0E0;
        border-radius: 50px;
        padding: 14px 24px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        font-family: 'Montserrat', sans-serif;
    }
 
    .filter-reset:hover {
        background: #FF5858;
        color: white;
        border-color: #FF5858;
    }
 
    /* === СОВРЕМЕННАЯ АНИМАЦИЯ СУПЕРЛАЙКА === */
    .superlike-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
 
    .superlike-overlay.active {
        opacity: 1;
    }
 
    .superlike-backdrop {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% 50%, 
            rgba(255, 88, 88, 0.15) 0%, 
            rgba(255, 88, 88, 0.05) 40%, 
            transparent 70%);
        transform: scale(0);
        transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
 
    .superlike-overlay.active .superlike-backdrop {
        transform: scale(3);
    }
 
    .superlike-star {
        position: relative;
        width: 120px;
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        transform: scale(0) rotate(-180deg);
        transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
 
    .superlike-overlay.active .superlike-star {
        transform: scale(1) rotate(0deg);
    }
 
    .superlike-star svg {
        width: 80px;
        height: 80px;
        fill: url(#superlikeGradient);
        filter: drop-shadow(0 8px 32px rgba(255, 88, 88, 0.4));
        animation: starPulse 0.6s ease 0.3s;
    }
 
    @@keyframes starPulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.2); }
    }
 
    .superlike-ripple {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 3px solid rgba(255, 88, 88, 0.3);
        transform: scale(1);
        opacity: 0;
    }
 
    .superlike-overlay.active .superlike-ripple {
        animation: rippleOut 0.8s ease 0.2s forwards;
    }
 
    @@keyframes rippleOut {
        to {
            transform: scale(2.5);
            opacity: 0;
        }
    }
 
    .superlike-particles {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }
 
    .superlike-particle {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 8px;
        height: 8px;
        background: linear-gradient(135deg, #FF5858, #F857A6);
        border-radius: 50%;
        opacity: 0;
    }
 
    .superlike-overlay.active .superlike-particle {
        animation: particleBurst 0.8s ease 0.1s forwards;
    }
 
    @@keyframes particleBurst {
        0% {
            transform: translate(-50%, -50%) scale(1);
            opacity: 1;
        }
        100% {
            transform: translate(
                calc(-50% + var(--tx)), 
                calc(-50% + var(--ty))
            ) scale(0);
            opacity: 0;
        }
    }
 
    /* Текст "СУПЕРЛАЙК!" */
    .superlike-text {
        position: absolute;
        top: calc(50% + 100px);
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        opacity: 0;
        font-size: 24px;
        font-weight: 800;
        background: linear-gradient(135deg, #FF5858, #F857A6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: 4px;
        text-transform: uppercase;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s;
    }
 
    .superlike-overlay.active .superlike-text {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
 
    /* Карточка улетает вверх с эффектом "взлёта" */
    .profile-card.superliked {
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateY(-150%) scale(0.8) rotate(5deg);
        opacity: 0;
        filter: brightness(1.2);
    }
 
    /* Оригинальные стили режимов */
    .mode-switcher {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-bottom: 16px;
    }
 
    .mode-btn {
        padding: 12px 28px;
        border-radius: 24px;
        border: 2px solid #FFE0E0;
        background: white;
        color: #636E72;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Montserrat', sans-serif;
    }
 
    .mode-btn.active {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 20px rgba(255,88,88,0.4);
        transform: translateY(-2px);
    }
 
    .mode-btn:hover:not(.active) {
        border-color: #FF5858;
        color: #FF5858;
        transform: translateY(-1px);
    }
 
    /* Подсказка свайпа */
    .swipe-hint {
        text-align: center;
        margin-bottom: 20px;
        padding: 12px 24px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        gap: 24px;
        margin: 0 auto 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border: 1px solid rgba(255, 88, 88, 0.1);
    }
 
    .swipe-hint-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        font-weight: 600;
        color: #636E72;
    }
 
    .swipe-hint-arrow {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 700;
        transition: transform 0.2s;
    }
 
    .swipe-hint-arrow.left {
        background: #FFE0E0;
        color: #FF5858;
    }
 
    .swipe-hint-arrow.right {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        color: white;
        box-shadow: 0 2px 8px rgba(255,88,88,0.3);
    }
 
    .hint-container {
        display: flex;
        justify-content: center;
    }
 
    /* Контейнеры */
    .view-wrapper {
        display: none;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
 
    .view-wrapper.active {
        display: block;
        opacity: 1;
    }
 
    .cards-container {
        position: relative;
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
        height: 520px;
        perspective: 1000px;
    }
 
    /* Карточки профилей */
    .profile-card {
        position: absolute;
        width: 100%;
        height: 100%;
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        cursor: grab;
        user-select: none;
        touch-action: none;
        will-change: transform;
        transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease;
    }
 
    .profile-card:active {
        cursor: grabbing;
    }
 
    .profile-card.swiping {
        transition: none;
    }
 
    .card-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
    }
 
    .card-gradient {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60%;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
        pointer-events: none;
    }
 
    .card-info {
        position: absolute;
        bottom: 20px;
        left: 24px;
        right: 24px;
        color: white;
        z-index: 5;
    }
 
    .card-name {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 12px;
        display: flex;
        align-items: baseline;
        gap: 12px;
    }
 
    .card-age {
        font-size: 22px;
        font-weight: 600;
        opacity: 0.9;
    }
 
    .card-meta-row {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 12px;
        flex-wrap: wrap;
    }
 
    .card-meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 15px;
        opacity: 0.95;
    }
 
    .card-goal {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        background: rgba(255, 88, 88, 0.85);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        font-size: 14px;
        font-weight: 700;
        color: white;
        margin-top: 8px;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
 
    /* Индикатор онлайн */
    .online-indicator {
        position: absolute;
        bottom: 8px;
        right: 8px;
        width: 16px;
        height: 16px;
        background: #00C853;
        border-radius: 50%;
        border: 3px solid white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        z-index: 10;
    }
 
    .online-indicator::after {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        border: 2px solid #00C853;
        animation: pulse-ring 2s infinite;
    }
 
    @@keyframes pulse-ring {
        0% { transform: scale(1); opacity: 1; }
        100% { transform: scale(1.5); opacity: 0; }
    }
 
    .online-text {
        position: absolute;
        bottom: 20px;
        left: 24px;
        background: rgba(0, 200, 83, 0.9);
        color: white;
        padding: 6px 14px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 700;
        z-index: 5;
        backdrop-filter: blur(4px);
    }
 
    /* Кнопки действий */
    .swipe-actions {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 24px;
        padding: 0 20px;
    }
 
    .action-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        background: white;
    }
 
    .action-circle:hover {
        transform: scale(1.15);
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }
 
    .action-circle:active {
        transform: scale(0.95);
    }
 
    .btn-nope {
        color: #FF5858;
        border: 3px solid #FFE0E0;
    }
 
    .btn-nope:hover {
        background: #FFF5F7;
        border-color: #FF5858;
    }
 
    .btn-superlike {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        width: 56px;
        height: 56px;
        margin-top: 4px;
    }
 
    .btn-like {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        color: white;
    }
 
    .btn-info {
        color: #636E72;
        border: 2px solid #EFEFEF;
        width: 48px;
        height: 48px;
        margin-top: 8px;
    }
 
    .btn-info:hover {
        border-color: #FF5858;
        color: #FF5858;
    }
 
    /* Индикаторы карточек */
    .indicators {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 16px;
    }
 
    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #E0E0E0;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
 
    .dot.active {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        width: 24px;
        border-radius: 4px;
    }
 
    /* Галерея */
    .gallery-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        padding: 0 20px;
    }
 
    .gallery-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
 
    .gallery-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }
 
    .gallery-image-wrap {
        position: relative;
        height: 380px;
        overflow: hidden;
        cursor: pointer;
    }
 
    .gallery-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
 
    .gallery-card:hover .gallery-image {
        transform: scale(1.08);
    }
 
    .gallery-gradient {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 70%;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%);
    }
 
    .gallery-info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 24px;
        color: white;
    }
 
    .gallery-name {
        font-size: 26px;
        font-weight: 800;
        margin-bottom: 8px;
        display: flex;
        align-items: baseline;
        gap: 10px;
    }
 
    .gallery-age {
        font-size: 18px;
        font-weight: 600;
        opacity: 0.9;
    }
 
    .gallery-meta {
        display: flex;
        gap: 16px;
        font-size: 14px;
        opacity: 0.95;
        flex-wrap: wrap;
    }
 
    .gallery-actions {
        padding: 20px;
        display: flex;
        gap: 12px;
        background: white;
        border-top: 1px solid #F0F0F0;
    }
 
    .gallery-btn {
        flex: 1;
        height: 48px;
        border-radius: 12px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
    }
 
    .gallery-btn-primary {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        color: white !important;
    }
 
    .gallery-btn-primary:hover {
        transform: scale(1.03);
        box-shadow: 0 8px 20px rgba(255,88,88,0.4);
    }
 
    .like-btn-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        border: 2px solid #E0E0E0;
        background: #F8F9FA;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        flex-shrink: 0;
    }
 
    .like-btn-icon:hover {
        border-color: #FF5858;
        background: #FFF5F7;
        transform: scale(1.1);
    }
 
    .like-btn-icon svg {
        width: 22px;
        height: 22px;
        stroke: #636E72;
        fill: none;
        transition: all 0.3s;
    }
 
    .like-btn-icon.liked {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        border-color: transparent;
        transform: scale(1.05);
    }
 
    .like-btn-icon.liked svg {
        stroke: white;
        fill: white;
    }
 
    @@media (max-width: 768px) {
        .filters-bar {
            padding: 16px 20px;
        }
 
        .filter-group {
            min-width: 100%;
        }
 
        .gallery-container {
            grid-template-columns: 1fr;
        }
 
        .cards-container {
            height: 480px;
        }
 
        .card-name {
            font-size: 26px;
        }
 
        .swipe-actions {
            gap: 16px;
        }
 
        .action-circle {
            width: 56px;
            height: 56px;
        }
 
        .swipe-hint {
            gap: 16px;
            padding: 10px 16px;
        }
    }
</style>
 
<div class="feed-page">
    <!-- Фильтры по центру -->
    <div class="filters-wrapper">
        <div class="filters-bar">
            <form method="get" style="display: contents;">
                <div class="filter-group">
                    <label>Город</label>
                    <input type="text" name="City" value="@Model.City" class="filter-input" placeholder="Москва" />
                </div>
                
                <div class="filter-group">
                    <label>Возраст от</label>
                    <input type="number" name="MinAge" value="@Model.MinAge" class="filter-input" placeholder="18" min="18" max="100" />
                </div>
                
                <div class="filter-group">
                    <label>Возраст до</label>
                    <input type="number" name="MaxAge" value="@Model.MaxAge" class="filter-input" placeholder="99" min="18" max="100" />
                </div>
                
                <div class="filter-group">
                    <label>Цель</label>
                    <div class="custom-dropdown-wrapper" id="goalWrapper">
                        <input type="hidden" name="Goal" id="goalValue" value="@Model.Goal" />
                        <div class="custom-dropdown-trigger" onclick="toggleGoalDropdown(event)">
                            <span id="goalLabel">@(string.IsNullOrEmpty(Model.Goal) ? "Любая" : Model.Goal)</span>
                            <svg class="dropdown-arrow" id="goalArrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF5858" stroke-width="2.5">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </div>
                        <div class="custom-dropdown-menu" id="goalMenu">
                            <div class="custom-dropdown-item @(string.IsNullOrEmpty(Model.Goal) ? "selected" : "")" onclick="selectGoal('', 'Любая', this)">Любая</div>
                            <div class="custom-dropdown-item @(Model.Goal == "Дружба" ? "selected" : "")" onclick="selectGoal('Дружба', 'Дружба', this)">Дружба</div>
                            <div class="custom-dropdown-item @(Model.Goal == "Отношения" ? "selected" : "")" onclick="selectGoal('Отношения', 'Отношения', this)">Отношения</div>
                            <div class="custom-dropdown-item @(Model.Goal == "Брак" ? "selected" : "")" onclick="selectGoal('Брак', 'Брак', this)">Брак</div>
                            <div class="custom-dropdown-item @(Model.Goal == "Общение" ? "selected" : "")" onclick="selectGoal('Общение', 'Общение', this)">Общение</div>
                        </div>
                    </div>
                </div>
                
                <button type="submit" class="filter-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    Найти
                </button>
                
                @if (!string.IsNullOrEmpty(Model.City) || !string.IsNullOrEmpty(Model.Goal) || Model.MinAge.HasValue || Model.MaxAge.HasValue)
                {
                    <a href="/Feed" class="filter-reset">Сбросить</a>
                }
            </form>
        </div>
    </div>
 
    <!-- Переключатель режимов -->
    <div class="mode-switcher">
        <button class="mode-btn active" onclick="setMode('swipe')" id="swipeMode">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <circle cx="12" cy="12" r="3"></circle>
            </svg>
            Свайп
        </button>
        <button class="mode-btn" onclick="setMode('gallery')" id="galleryMode">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            Лента
        </button>
    </div>
    
    <!-- Подсказка свайпа -->
    <div class="hint-container" id="swipeHint">
        <div class="swipe-hint">
            <div class="swipe-hint-item">
                <span class="swipe-hint-arrow left">←</span>
                <span>Пропустить</span>
            </div>
            <div class="swipe-hint-item">
                <span>Нравится</span>
                <span class="swipe-hint-arrow right">→</span>
            </div>
        </div>
    </div>
    
    <!-- Свайп режим -->
    <div class="view-wrapper active" id="swipeView">
        <div class="cards-container" id="cardsContainer">
            @{
                var index = 0;
                foreach (var item in Model.Profiles.Take(10))
                {
                    var profile = item.Profile;
                    <div class="profile-card @(index == 0 ? "active" : "")" 
                         data-id="@profile.Id"
                         data-userid="@profile.UserId"
                         style="z-index: @(100 - index); transform: scale(@(1 - index * 0.05)) translateY(@(index * 10)px); opacity: @(1 - index * 0.15);">
                        
                        @if (!string.IsNullOrEmpty(profile.PhotoPath))
                        {
                            <div style="position: relative; width: 100%; height: 100%;">
                                <img src="@profile.PhotoPath" class="card-image" alt="@profile.Name" draggable="false" loading="eager" />
                                @if (item.IsOnline)
                                {
                                    <div class="online-indicator"></div>
                                    <div class="online-text">онлайн</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="card-image" style="background: linear-gradient(135deg, #FF5858, #F857A6); display:flex; align-items:center; justify-content:center; position: relative;">
                                <span style="color:white; font-size:72px; font-weight:800;">@(profile.Name.Substring(0, 1).ToUpper())</span>
                                @if (item.IsOnline)
                                {
                                    <div class="online-indicator"></div>
                                    <div class="online-text">онлайн</div>
                                }
                            </div>
                        }
                        
                        <div class="card-gradient"></div>
                        
                        <div class="card-info">
                            <div class="card-name">
                                @profile.Name
                                <span class="card-age">@profile.Age</span>
                            </div>
                            <div class="card-meta-row">
                                <span class="card-meta-item">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                        <circle cx="12" cy="10" r="3"></circle>
                                    </svg>
                                    @profile.City
                                </span>
                                @if (profile.HasChildren)
                                {
                                    <span class="card-meta-item">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"></circle>
                                            <path d="M12 8v8"></path>
                                            <path d="M8 12h8"></path>
                                        </svg>
                                        Есть дети
                                    </span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(profile.Goal))
                            {
                                <div class="card-goal">@profile.Goal</div>
                            }
                        </div>
                    </div>
                    index++;
                }
            }
        </div>
        
        <div class="indicators" id="indicators">
            @for (int i = 0; i < Math.Min(Model.Profiles.Count, 10); i++)
            {
                <div class="dot @(i == 0 ? "active" : "")"></div>
            }
        </div>
        
        <div class="swipe-actions">
            <button class="action-circle btn-nope" onclick="swipeLeft()" title="Пропустить">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            
            <button class="action-circle btn-info" onclick="openCurrentProfile()" title="Подробнее">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="16" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
            </button>
            
            <button class="action-circle btn-superlike" onclick="superLike()" title="Суперлайк">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
            </button>
            
            <button class="action-circle btn-like" onclick="swipeRight()" title="Нравится">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
            </button>
        </div>
    </div>
    
    <!-- Галерея режим -->
    <div class="view-wrapper" id="galleryView">
        <div class="gallery-container">
            @foreach (var item in Model.Profiles)
            {
                var profile = item.Profile;
                <div class="gallery-card">
                    <div class="gallery-image-wrap" onclick="window.location.href='/Profile/View/@profile.Id'">
                        @if (!string.IsNullOrEmpty(profile.PhotoPath))
                        {
                            <div style="position: relative; width: 100%; height: 100%;">
                                <img src="@profile.PhotoPath" class="gallery-image" alt="@profile.Name" loading="lazy" />
                                @if (item.IsOnline)
                                {
                                    <div class="online-indicator" style="bottom: 80px;"></div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="gallery-image" style="background: linear-gradient(135deg, #FF5858, #F857A6); display:flex; align-items:center; justify-content:center; position: relative;">
                                <span style="color:white; font-size:64px; font-weight:800;">@(profile.Name.Substring(0, 1).ToUpper())</span>
                                @if (item.IsOnline)
                                {
                                    <div class="online-indicator" style="bottom: 80px;"></div>
                                }
                            </div>
                        }
                        <div class="gallery-gradient"></div>
                        <div class="gallery-info">
                            <div class="gallery-name">
                                @profile.Name
                                <span class="gallery-age">@profile.Age</span>
                            </div>
                            <div class="gallery-meta">
                                <span>@profile.City</span>
                                @if (!string.IsNullOrEmpty(profile.Goal))
                                {
                                    <span>• @profile.Goal</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="gallery-actions">
                        <a href="/Messages/Dialog/@profile.UserId" class="gallery-btn gallery-btn-primary">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                            </svg>
                            Написать
                        </a>
                        <button type="button" class="like-btn-icon" 
                                data-profile-id="@profile.Id"
                                onclick="toggleLike(this, @profile.Id)">
                            <svg viewBox="0 0 24 24" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
    
    <!-- Современная анимация суперлайка -->
    <div class="superlike-overlay" id="superlikeOverlay">
        <svg width="0" height="0" style="position:absolute">
            <defs>
                <linearGradient id="superlikeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#FF5858"/>
                    <stop offset="100%" style="stop-color:#F857A6"/>
                </linearGradient>
            </defs>
        </svg>
        <div class="superlike-backdrop"></div>
        <div class="superlike-star">
            <svg viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            <div class="superlike-ripple"></div>
        </div>
        <div class="superlike-particles" id="superlikeParticles"></div>
        <div class="superlike-text">Суперлайк!</div>
    </div>
</div>
 
<script>
    let currentCard = null;
    let startX = 0;
    let currentX = 0;
    let isDragging = false;
    let hasSwiped = false;
 
    // Dropdown функции
    function toggleGoalDropdown(e) {
        e.stopPropagation();
        const wrapper = document.getElementById('goalWrapper');
        wrapper.classList.toggle('active');
    }
 
    function selectGoal(value, label, el) {
        document.getElementById('goalValue').value = value;
        document.getElementById('goalLabel').textContent = label;
        document.getElementById('goalLabel').style.color = value ? '#636E72' : '#2D3436';
        
        document.querySelectorAll('#goalMenu .custom-dropdown-item').forEach(item => {
            item.classList.remove('selected');
        });
        el.classList.add('selected');
        
        document.getElementById('goalWrapper').classList.remove('active');
    }
 
    // Закрыть dropdown при клике вне
    document.addEventListener('click', function(e) {
        if (!e.target.closest('#goalWrapper')) {
            document.getElementById('goalWrapper').classList.remove('active');
        }
    });
 
    function setMode(mode) {
        const swipeBtn = document.getElementById('swipeMode');
        const galleryBtn = document.getElementById('galleryMode');
        const swipeView = document.getElementById('swipeView');
        const galleryView = document.getElementById('galleryView');
        const swipeHint = document.getElementById('swipeHint');
 
        if (mode === 'swipe') {
            swipeBtn.classList.add('active');
            galleryBtn.classList.remove('active');
            swipeView.classList.add('active');
            galleryView.classList.remove('active');
            swipeHint.style.display = 'flex';
            setTimeout(() => initCard(), 50);
        } else {
            galleryBtn.classList.add('active');
            swipeBtn.classList.remove('active');
            galleryView.classList.add('active');
            swipeView.classList.remove('active');
            swipeHint.style.display = 'none';
        }
    }
 
    function initCard() {
        if (currentCard) {
            currentCard.removeEventListener('mousedown', startDrag);
            currentCard.removeEventListener('touchstart', startDrag);
        }
 
        currentCard = document.querySelector('.profile-card.active');
        if (!currentCard) return;
 
        currentCard.addEventListener('mousedown', startDrag);
        currentCard.addEventListener('touchstart', startDrag, {passive: false});
    }
 
    function startDrag(e) {
        if (hasSwiped) return;
        isDragging = true;
        currentCard.classList.add('swiping');
        startX = e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
 
        document.addEventListener('mousemove', drag);
        document.addEventListener('mouseup', endDrag);
        document.addEventListener('touchmove', drag, {passive: false});
        document.addEventListener('touchend', endDrag);
    }
 
    function drag(e) {
        if (!isDragging || !currentCard) return;
        e.preventDefault();
 
        const x = e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
        currentX = x - startX;
        const rotate = currentX * 0.08;
        const scale = 1 - Math.abs(currentX) / 3000;
 
        currentCard.style.transform = `translateX(${currentX}px) rotate(${rotate}deg) scale(${scale})`;
    }
 
    function endDrag(e) {
        if (!isDragging || !currentCard) return;
        isDragging = false;
        currentCard.classList.remove('swiping');
 
        document.removeEventListener('mousemove', drag);
        document.removeEventListener('mouseup', endDrag);
        document.removeEventListener('touchmove', drag);
        document.removeEventListener('touchend', endDrag);
 
        const threshold = 100;
        if (currentX > threshold) {
            swipeRight();
        } else if (currentX < -threshold) {
            swipeLeft();
        } else {
            currentCard.style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
            currentCard.style.transform = '';
            
            setTimeout(() => {
                currentCard.style.transition = '';
            }, 500);
        }
        currentX = 0;
    }
 
    function swipeLeft() {
        if (!currentCard || hasSwiped) return;
        hasSwiped = true;
 
        const profileId = currentCard.dataset.id;
        fetch(`/Feed/Pass?id=${profileId}`, {method: 'POST'});
 
        currentCard.style.transition = 'all 0.6s ease';
        currentCard.style.transform = 'translateX(-120%) rotate(-25deg)';
        currentCard.style.opacity = '0';
 
        setTimeout(() => nextCard(), 600);
    }
 
    function swipeRight() {
        if (!currentCard || hasSwiped) return;
        hasSwiped = true;
 
        const profileId = currentCard.dataset.id;
        fetch(`/Feed/Like?id=${profileId}`, {method: 'POST'});
 
        currentCard.style.transition = 'all 0.6s ease';
        currentCard.style.transform = 'translateX(120%) rotate(25deg)';
        currentCard.style.opacity = '0';
 
        setTimeout(() => nextCard(), 600);
    }
 
    // === СОВРЕМЕННАЯ АНИМАЦИЯ СУПЕРЛАЙКА ===
    function superLike() {
        if (!currentCard || hasSwiped) return;
        hasSwiped = true;
 
        const overlay = document.getElementById('superlikeOverlay');
        const particlesContainer = document.getElementById('superlikeParticles');
        
        // Генерируем частицы
        particlesContainer.innerHTML = '';
        const particleCount = 12;
        for (let i = 0; i < particleCount; i++) {
            const angle = (i / particleCount) * Math.PI * 2;
            const distance = 100 + Math.random() * 60;
            const tx = Math.cos(angle) * distance;
            const ty = Math.sin(angle) * distance;
            
            const particle = document.createElement('div');
            particle.className = 'superlike-particle';
            particle.style.setProperty('--tx', `${tx}px`);
            particle.style.setProperty('--ty', `${ty}px`);
            particle.style.animationDelay = `${Math.random() * 0.1}s`;
            particlesContainer.appendChild(particle);
        }
 
        // Показываем оверлей
        overlay.classList.add('active');
 
        // Отправляем запрос
        const profileId = currentCard.dataset.id;
        fetch(`/Feed/SuperLike?id=${profileId}`, {method: 'POST'});
 
        // Анимация карточки
        currentCard.classList.add('superliked');
 
        // Очищаем и переходим дальше
        setTimeout(() => {
            overlay.classList.remove('active');
            nextCard();
        }, 1200);
    }
 
    function nextCard() {
        if (!currentCard) return;
        
        currentCard.remove();
        hasSwiped = false;
 
        const activeDot = document.querySelector('.dot.active');
        if (activeDot) {
            activeDot.classList.remove('active');
            const nextDot = activeDot.nextElementSibling;
            if (nextDot) nextDot.classList.add('active');
        }
 
        const cards = document.querySelectorAll('.profile-card');
        if (cards.length > 0) {
            cards[0].classList.add('active');
            cards.forEach((card, i) => {
                card.style.zIndex = 100 - i;
                card.style.transform = `scale(${1 - i * 0.05}) translateY(${i * 10}px)`;
                card.style.opacity = 1 - i * 0.15;
            });
            initCard();
        } else {
            location.reload();
        }
    }
 
    function openCurrentProfile() {
        if (!currentCard) return;
        window.location.href = `/Profile/View/${currentCard.dataset.id}`;
    }
 
    function toggleLike(btn, profileId) {
        const isLiked = btn.classList.contains('liked');
 
        if (isLiked) {
            fetch(`/Feed/Unlike?id=${profileId}`, {method: 'POST'})
                .then(() => btn.classList.remove('liked'));
        } else {
            fetch(`/Feed/Like?id=${profileId}`, {method: 'POST'})
                .then(() => btn.classList.add('liked'));
        }
    }
 
    document.addEventListener('keydown', (e) => {
        if (!document.getElementById('swipeView').classList.contains('active')) return;
        if (e.key === 'ArrowLeft') swipeLeft();
        if (e.key === 'ArrowRight') swipeRight();
        if (e.key === 'ArrowUp') superLike();
    });
 
    window.addEventListener('beforeunload', () => {
        if (currentCard) {
            currentCard.removeEventListener('mousedown', startDrag);
            currentCard.removeEventListener('touchstart', startDrag);
        }
        document.removeEventListener('mousemove', drag);
        document.removeEventListener('mouseup', endDrag);
        document.removeEventListener('touchmove', drag);
        document.removeEventListener('touchend', endDrag);
    });
 
    initCard();
</script>
 