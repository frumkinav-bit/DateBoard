@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@using DateBoard.Data
@inject ApplicationDbContext Db

<div style="display: flex; align-items: center; gap: 25px;">
    @if (SignInManager.IsSignedIn(User))
    {
        var profileCount = Db.Profiles.Count();
        var currentUser = await UserManager.GetUserAsync(User);
        var userProfile = Db.Profiles.FirstOrDefault(p => p.UserId == currentUser.Id);
        var initial = userProfile?.Name?.Substring(0, 1)?.ToUpper() ?? User.Identity?.Name?.Substring(0, 1)?.ToUpper() ?? "?";
        var userName = userProfile?.Name ?? User.Identity?.Name?.Split('@')[0] ?? "Профиль";

        //<!-- Счётчик анкет -->
       // <div style="display: flex; align-items: center; gap: 6px; background: rgba(255,88,88,0.06); border: 1px solid rgba(255,88,88,0.15); border-radius: 50px; padding: 6px 14px;">
            //<div style="width: 6px; height: 6px; border-radius: 50%; background: #FF5858;"></div>
            //<span style="font-size: 12px; color: #FF5858; font-weight: 600;">@profileCount анкет</span>
        //</div>

        <!-- Аватарка + имя -->
        <a asp-area="Identity" asp-page="/Account/Manage/Index"
           style="display: flex; align-items: center; gap: 8px; text-decoration: none;">
            @if (!string.IsNullOrEmpty(userProfile?.PhotoPath))
            {
                <img src="@userProfile.PhotoPath" style="width:34px; height:34px; border-radius:50%; object-fit:cover; border: 2px solid #FF5858;" />
            }
            else
            {
                <div style="width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#FF5858,#F857A6); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <span style="color:white; font-size:13px; font-weight:700;">@initial</span>
                </div>
            }
            <span style="font-size: 13px; font-weight: 500; color: #2D3436;">@userName</span>
        </a>

        <!-- Кнопка выйти -->
        <form asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" style="margin: 0;">
            <button type="submit" style="background: transparent; border: 1px solid #DDDDDD; border-radius: 20px; color: #636E72; font-size: 13px; padding: 6px 16px; font-weight: 500; cursor: pointer; font-family: 'Montserrat', sans-serif; transition: all 0.2s;"
                    onmouseover="this.style.borderColor='#FF5858'; this.style.color='#FF5858'"
                    onmouseout="this.style.borderColor='#DDDDDD'; this.style.color='#636E72'">
                Выйти
            </button>
        </form>
    }
    else
    {
        <a asp-area="Identity" asp-page="/Account/Login"
           style="font-size: 13px; color: #636E72 !important; font-weight: 500; padding: 6px 16px; text-decoration: none;"
           onmouseover="this.style.color='#FF5858'"
           onmouseout="this.style.color='#636E72'">
            Войти
        </a>
        <a asp-area="Identity" asp-page="/Account/Register"
           class="btn btn-primary"
           style="font-size: 13px !important; padding: 8px 20px !important;">
            Регистрация
        </a>
    }
</div>