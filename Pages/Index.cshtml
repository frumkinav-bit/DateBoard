<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DateBoard</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DateBoard.styles.css" asp-append-version="true" />
    
    <style>
            * {
                font-family: 'Montserrat', sans-serif;
            }
        
            /* ===== НОВАЯ ШАПКА ===== */
            .navbar-custom {
                background: white;
                border-bottom: 1px solid #F0F0F0;
                box-shadow: 0 2px 20px rgba(0,0,0,0.06);
                height: 70px;
            }
        
            .navbar-brand {
                font-size: 24px;
                font-weight: 800;
                text-decoration: none;
            }
        
            .nav-main-links {
                display: flex;
                gap: 8px;
                align-items: center;
            }
        
            .nav-link-main {
                color: #636E72;
                font-size: 14px;
                font-weight: 600;
                padding: 10px 20px;
                border-radius: 25px;
                text-decoration: none;
                transition: all 0.3s ease;
                position: relative;
            }
        
                .nav-link-main:hover {
                    color: #FF5858;
                    background: rgba(255, 88, 88, 0.08);
                }
        
                .nav-link-main.active {
                    color: #FF5858;
                    background: linear-gradient(135deg, rgba(255,88,88,0.1), rgba(248,87,166,0.1));
                }
        
                    .nav-link-main.active::after {
                        content: '';
                        position: absolute;
                        bottom: 2px;
                        left: 50%;
                        transform: translateX(-50%);
                        width: 4px;
                        height: 4px;
                        background: #FF5858;
                        border-radius: 50%;
                    }
        
            /* Поиск */
            .nav-search {
                position: relative;
                margin-right: 15px;
            }
        
            .search-toggle {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                border: none;
                background: #F8F9FA;
                color: #636E72;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                transition: all 0.3s ease;
            }
        
                .search-toggle:hover {
                    background: rgba(255, 88, 88, 0.1);
                    color: #FF5858;
                }
        
            .search-dropdown {
                position: absolute;
                top: calc(100% + 10px);
                right: 0;
                width: 320px;
                background: white;
                border-radius: 20px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.15);
                padding: 20px;
                opacity: 0;
                visibility: hidden;
                transform: translateY(-10px);
                transition: all 0.3s ease;
                z-index: 1000;
            }
        
                .search-dropdown.active {
                    opacity: 1;
                    visibility: visible;
                    transform: translateY(0);
                }
        
            .search-input {
                width: 100%;
                border: 2px solid #F0F0F0;
                border-radius: 15px;
                padding: 12px 20px;
                font-size: 14px;
                outline: none;
                transition: all 0.3s ease;
            }
        
                .search-input:focus {
                    border-color: #FF5858;
                }
        
            /* Уведомления */
            .nav-notification {
                position: relative;
                margin-right: 15px;
            }
 
            .notification-btn {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                border: none;
                background: #F8F9FA;
                color: #636E72;
                cursor: pointer;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
            }
 
                .notification-btn:hover {
                    background: rgba(255, 88, 88, 0.1);
                    color: #FF5858;
                }
 
            .notification-badge {
                position: absolute;
                top: 2px;
                right: 2px;
                background: linear-gradient(135deg, #FF5858, #F857A6);
                color: white;
                font-size: 10px;
                font-weight: 700;
                min-width: 18px;
                height: 18px;
                border-radius: 9px;
                display: none;
                align-items: center;
                justify-content: center;
                padding: 0 5px;
                box-shadow: 0 2px 8px rgba(255, 88, 88, 0.4);
            }
 
            .notification-dropdown {
                position: absolute;
                top: calc(100% + 10px);
                right: -10px;
                width: 380px;
                background: white;
                border-radius: 20px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.15);
                opacity: 0;
                visibility: hidden;
                transform: translateY(-10px) scale(0.95);
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                z-index: 1000;
                overflow: hidden;
            }
 
            @@media (max-width: 768px) {
                .notification-dropdown {
                    width: 300px;
                    right: -50px;
                }
            }
 
            .notification-dropdown.active {
                opacity: 1;
                visibility: visible;
                transform: translateY(0) scale(1);
            }
 
            .notification-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px 24px;
                border-bottom: 1px solid #F0F0F0;
                background: linear-gradient(135deg, #FFF5F7 0%, white 100%);
            }
 
                .notification-header span {
                    font-weight: 700;
                    font-size: 16px;
                    color: #2D3436;
                }
 
                .notification-header button {
                    background: none;
                    border: none;
                    color: #FF5858;
                    font-size: 13px;
                    font-weight: 600;
                    cursor: pointer;
                    padding: 6px 12px;
                    border-radius: 12px;
                    transition: all 0.2s;
                }
 
                    .notification-header button:hover {
                        background: rgba(255, 88, 88, 0.1);
                    }
 
            .notification-list {
                max-height: 420px;
                overflow-y: auto;
            }
 
                .notification-list::-webkit-scrollbar {
                    width: 6px;
                }
 
                .notification-list::-webkit-scrollbar-track {
                    background: #F8F9FA;
                }
 
                .notification-list::-webkit-scrollbar-thumb {
                    background: #E0E0E0;
                    border-radius: 3px;
                }
 
            .notification-item {
                display: flex;
                gap: 14px;
                padding: 16px 24px;
                border-bottom: 1px solid #F8F9FA;
                cursor: pointer;
                transition: all 0.2s;
                text-decoration: none;
            }
 
                .notification-item:hover {
                    background: #F8F9FA;
                }
 
                .notification-item.unread {
                    background: linear-gradient(90deg, #FFF5F7 0%, white 100%);
                    border-left: 3px solid #FF5858;
                }
 
            .notification-avatar {
                width: 48px;
                height: 48px;
                border-radius: 50%;
                object-fit: cover;
                flex-shrink: 0;
                box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            }
 
            .notification-avatar-placeholder {
                width: 48px;
                height: 48px;
                border-radius: 50%;
                background: linear-gradient(135deg, #FF5858, #F857A6);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: 700;
                font-size: 20px;
                flex-shrink: 0;
            }
 
            .notification-content {
                flex: 1;
                min-width: 0;
            }
 
            .notification-text {
                font-size: 14px;
                color: #2D3436;
                margin-bottom: 6px;
                line-height: 1.4;
                font-weight: 500;
            }
 
                .notification-text strong {
                    color: #FF5858;
                    font-weight: 700;
                }
 
            .notification-time {
                font-size: 12px;
                color: #636E72;
                font-weight: 500;
            }
 
            .notification-empty {
                text-align: center;
                padding: 60px 20px;
                color: #636E72;
                font-size: 14px;
            }
 
            .notification-empty-icon {
                width: 64px;
                height: 64px;
                margin: 0 auto 16px;
                background: #F8F9FA;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #CCC;
            }
        
            /* Профиль меню */
            .profile-menu {
                position: relative;
            }
        
            .profile-btn {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 6px 6px 6px 15px;
                border-radius: 50px;
                border: 2px solid #F0F0F0;
                background: white;
                cursor: pointer;
                transition: all 0.3s ease;
            }
        
                .profile-btn:hover {
                    border-color: #FF5858;
                    box-shadow: 0 4px 15px rgba(255,88,88,0.15);
                }
        
            .profile-avatar-small {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: linear-gradient(135deg, #FF5858, #F857A6);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: 700;
                font-size: 14px;
            }
        
            .profile-arrow {
                color: #636E72;
                transition: transform 0.3s ease;
            }
        
            .profile-btn.active .profile-arrow {
                transform: rotate(180deg);
            }
        
            .profile-dropdown {
                position: absolute;
                top: calc(100% + 10px);
                right: 0;
                width: 280px;
                background: white;
                border-radius: 20px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.15);
                opacity: 0;
                visibility: hidden;
                transform: translateY(-10px) scale(0.95);
                transition: all 0.3s ease;
                z-index: 1000;
                overflow: hidden;
                padding: 10px;
            }
        
                .profile-dropdown.active {
                    opacity: 1;
                    visibility: visible;
                    transform: translateY(0) scale(1);
                }
        
            .profile-dropdown-header {
                padding: 20px;
                background: linear-gradient(135deg, #FFF5F7 0%, white 100%);
                border-radius: 15px;
                margin-bottom: 10px;
            }
        
            .profile-dropdown-name {
                font-size: 16px;
                font-weight: 700;
                color: #2D3436;
                margin-bottom: 4px;
            }
        
            .profile-dropdown-email {
                font-size: 13px;
                color: #636E72;
            }
        
            .profile-menu-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 15px;
                border-radius: 12px;
                color: #636E72;
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
                transition: all 0.2s ease;
                margin-bottom: 4px;
            }
        
                .profile-menu-item:hover {
                    background: rgba(255, 88, 88, 0.08);
                    color: #FF5858;
                }
        
                .profile-menu-item svg {
                    width: 20px;
                    height: 20px;
                }
        
            .profile-menu-divider {
                height: 1px;
                background: #F0F0F0;
                margin: 10px 0;
            }
        
            .profile-menu-item.logout {
                color: #FF5858;
            }
        
                .profile-menu-item.logout:hover {
                    background: rgba(255, 88, 88, 0.1);
                }
 
            /* Toast уведомление */
            .toast-container {
                position: fixed;
                top: 90px;
                right: 20px;
                z-index: 9999;
                display: flex;
                flex-direction: column;
                gap: 12px;
            }
 
            @@media (max-width: 768px) {
                .toast-container {
                    top: 80px;
                    right: 10px;
                    left: 10px;
                }
            }
 
            .toast {
                background: white;
                border-radius: 16px;
                padding: 16px 20px;
                box-shadow: 0 10px 40px rgba(0,0,0,0.15);
                display: flex;
                align-items: center;
                gap: 14px;
                min-width: 320px;
                max-width: 400px;
                transform: translateX(120%);
                transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
                border-left: 4px solid #FF5858;
            }
 
            @@media (max-width: 768px) {
                .toast {
                    min-width: auto;
                    max-width: 100%;
                }
            }
 
            .toast.show {
                transform: translateX(0);
            }
 
            .toast-avatar {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                object-fit: cover;
            }
 
            .toast-content {
                flex: 1;
            }
 
            .toast-title {
                font-size: 14px;
                font-weight: 700;
                color: #2D3436;
                margin-bottom: 4px;
            }
 
            .toast-message {
                font-size: 13px;
                color: #636E72;
            }
 
            .toast-close {
                background: none;
                border: none;
                color: #CCC;
                cursor: pointer;
                padding: 4px;
                transition: color 0.2s;
            }
 
                .toast-close:hover {
                    color: #FF5858;
                }
 
            /* Мобильная адаптация */
            @@media (max-width: 991px) {
                .navbar-collapse {
                    background: white;
                    padding: 20px;
                    border-radius: 0 0 20px 20px;
                    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
                    position: absolute;
                    top: 70px;
                    left: 0;
                    right: 0;
                    z-index: 1000;
                }
            
                .nav-main-links {
                    flex-direction: column;
                    width: 100%;
                    margin-bottom: 15px;
                }
            
                .nav-link-main {
                    width: 100%;
                    text-align: center;
                }
            
                .navbar-nav-right {
                    flex-direction: column;
                    width: 100%;
                    gap: 10px;
                }
            
                .nav-search, .nav-notification {
                    margin-right: 0;
                }
            
                .search-dropdown, .notification-dropdown, .profile-dropdown {
                    position: fixed;
                    top: auto;
                    left: 10px;
                    right: 10px;
                    width: auto;
                }
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container">
                <!-- Логотип -->
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <span style="color: #2D3436;">Date</span>
                    <span style="background: linear-gradient(135deg, #FF5858, #F857A6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Board</span>
                </a>
 
                <!-- Кнопка бургер для мобильных -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
 
                <!-- Меню -->
                <div class="collapse navbar-collapse" id="mainNav">
                    <!-- Основные ссылки (только 3) -->
                    <div class="nav-main-links mx-auto">
                        <a class="nav-link-main @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Index" ? "active" : "")"
                           asp-page="/Index">Главная</a>
                        <a class="nav-link-main @(ViewContext.RouteData.Values["Page"]?.ToString()?.StartsWith("/Feed") == true ? "active" : "")"
                           asp-page="/Feed/Index">Лента</a>
                        <a class="nav-link-main @(ViewContext.RouteData.Values["Page"]?.ToString()?.StartsWith("/Chat") == true ? "active" : "")"
                           asp-page="/Chat/Index">Чат</a>
                    </div>
 
                    <!-- Правая часть -->
                    <div class="d-flex align-items-center navbar-nav-right ms-lg-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <!-- Поиск -->
                            <div class="nav-search">
                                <button class="search-toggle" onclick="toggleSearch()" title="Поиск">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <circle cx="11" cy="11" r="8"></circle>
                                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                    </svg>
                                </button>
                                <div class="search-dropdown" id="searchDropdown">
                                    <input type="text" class="search-input" placeholder="Поиск по анкетам..."
                                           onkeypress="if(event.key==='Enter'){window.location.href='/Feed/Index?search='+this.value}">
                                </div>
                            </div>
 
                            <!-- Уведомления -->
                            <div class="nav-notification">
                                <button class="notification-btn" onclick="toggleNotifications()" title="Уведомления">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                        <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                                    </svg>
                                    <span class="notification-badge" id="notificationCount">0</span>
                                </button>
 
                                <div class="notification-dropdown" id="notificationDropdown">
                                    <div class="notification-header">
                                        <span>Уведомления</span>
                                        <button onclick="markAllAsRead()">Прочитать все</button>
                                    </div>
                                    <div class="notification-list" id="notificationList">
                                        <div class="notification-empty">
                                            <div class="notification-empty-icon">
                                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                                                </svg>
                                            </div>
                                            Нет новых уведомлений
                                        </div>
                                    </div>
                                </div>
                            </div>
 
                            <!-- Меню профиля -->
                            <div class="profile-menu">
                                <button class="profile-btn" onclick="toggleProfileMenu()" id="profileBtn">
                                    <span style="font-size: 14px; font-weight: 600; color: #2D3436;">Меню</span>
                                    <div class="profile-avatar-small">
                                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <svg class="profile-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="6 9 12 15 18 9"></polyline>
                                    </svg>
                                </button>
 
                                <div class="profile-dropdown" id="profileDropdown">
                                    <div class="profile-dropdown-header">
                                        <div class="profile-dropdown-name">@(User.Identity.Name ?? "Пользователь")</div>
                                        <div class="profile-dropdown-email">Моя анкета активна</div>
                                    </div>
                                    
                                    <a href="/Profile/Edit" class="profile-menu-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                            <circle cx="12" cy="7" r="4"></circle>
                                        </svg>
                                        Моя анкета
                                    </a>
                                    
                                    <a href="/Likes/Index" class="profile-menu-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                                        </svg>
                                        Лайки
                                    </a>
                                    
                                    <a href="/Favorites/Index" class="profile-menu-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                                        </svg>
                                        Избранное
                                    </a>
                                    
                                    <a href="/Messages/Index" class="profile-menu-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                                        </svg>
                                        Личные сообщения
                                    </a>
                                    
                                    <div class="profile-menu-divider"></div>
                                    
                                    <a href="/Identity/Account/Manage" class="profile-menu-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="3"></circle>
                                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                        </svg>
                                        Настройки
                                    </a>
                                    
                                    <form method="post" action="/Identity/Account/Logout" style="margin: 0;">
                                        <button type="submit" class="profile-menu-item logout" style="width: 100%; border: none; background: none; cursor: pointer;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                                <polyline points="16 17 21 12 16 7"></polyline>
                                                <line x1="21" y1="12" x2="9" y2="12"></line>
                                            </svg>
                                            Выйти
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <partial name="_LoginPartial" />
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
 
    <!-- Toast контейнер -->
    <div class="toast-container" id="toastContainer"></div>
 
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
 
    <footer class="border-top bg-white mt-auto" style="padding: 20px 0;">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="text-muted" style="font-size: 13px;">© 2026 DateBoard</span>
            <a asp-area="" asp-page="/Privacy" class="text-muted" style="font-size: 13px; text-decoration: none;">
                Политика конфиденциальности
            </a>
        </div>
    </footer>
 
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
            // Поиск
            function toggleSearch() {
                const dropdown = document.getElementById('searchDropdown');
                dropdown.classList.toggle('active');
                if (dropdown.classList.contains('active')) {
                    dropdown.querySelector('input').focus();
                    document.addEventListener('click', closeSearchOutside);
                }
            }
        
            function closeSearchOutside(e) {
                if (!e.target.closest('.nav-search')) {
                    document.getElementById('searchDropdown').classList.remove('active');
                    document.removeEventListener('click', closeSearchOutside);
                }
            }
 
            // Профиль меню
            function toggleProfileMenu() {
                const dropdown = document.getElementById('profileDropdown');
                const btn = document.getElementById('profileBtn');
                const isActive = dropdown.classList.toggle('active');
                btn.classList.toggle('active', isActive);
            
                if (isActive) {
                    setTimeout(() => {
                        document.addEventListener('click', closeProfileOutside);
                    }, 100);
                }
            }
        
            function closeProfileOutside(e) {
                if (!e.target.closest('.profile-menu')) {
                    document.getElementById('profileDropdown').classList.remove('active');
                    document.getElementById('profileBtn').classList.remove('active');
                    document.removeEventListener('click', closeProfileOutside);
                }
            }
 
            // Уведомления (заглушки)
            function toggleNotifications() {
                const dropdown = document.getElementById('notificationDropdown');
                dropdown.classList.toggle('active');
            }
        
            function markAllAsRead() {
                console.log('Mark all as read');
            }
    </script>
    
    @if (User.Identity.IsAuthenticated)
    {
        <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
        <script>
                // SignalR код для уведомлений (как раньше)
                let notificationConnection = null;
                let currentUserId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
 
                async function initNotifications() {
                    if (!currentUserId) return;
 
                    notificationConnection = new signalR.HubConnectionBuilder()
                        .withUrl("/notificationHub")
                        .withAutomaticReconnect([0, 2000, 5000, 10000])
                        .build();
 
                    notificationConnection.on("ReceiveNotification", function(type, message, fromUserId, fromName, fromPhoto) {
                        showToast(type, message, fromName, fromPhoto);
                        updateNotificationCount();
                    });
 
                    notificationConnection.on("UpdateCount", function(count) {
                        updateBadge(count);
                    });
 
                    try {
                        await notificationConnection.start();
                        await notificationConnection.invoke("JoinGroup", currentUserId);
                        updateNotificationCount();
                    } catch (err) {
                        console.error("SignalR Error:", err);
                    }
                }
 
                async function updateNotificationCount() {
                    try {
                        const response = await fetch('/api/notifications/count');
                        const count = await response.json();
                        updateBadge(count);
                    } catch (err) {
                        console.error("Error:", err);
                    }
                }
 
                function updateBadge(count) {
                    const badge = document.getElementById('notificationCount');
                    if (count > 0) {
                        badge.textContent = count > 99 ? '99+' : count;
                        badge.style.display = 'flex';
                    } else {
                        badge.style.display = 'none';
                    }
                }
 
                function showToast(type, message, fromName, fromPhoto) {
                    // Реализация toast
                }
 
                document.addEventListener('DOMContentLoaded', initNotifications);
        </script>
    }
 
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>