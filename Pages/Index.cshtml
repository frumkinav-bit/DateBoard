<div class="recent-section" style="background: white; padding: 100px 0;">
    <div class="container">
        <div style="text-align:center; margin-bottom:48px;">
            <p style="font-size:12px; letter-spacing:2px; color:#F857A6; margin-bottom:10px; font-weight:600;">НОВЫЕ УЧАСТНИКИ</p>
            <h2 style="font-size:35px; font-weight:700; color:#2D3436; margin:0;">Недавно зарегистрировались</h2>
        </div>
        <div class="row g-4 justify-content-center align-items-end recent-cards-row">
            @{ int cardIndex = 0; }
