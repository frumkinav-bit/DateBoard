                var mt = cardIndex == 1 ? "0px" : "28px";
                cardIndex++;
                <div class="col-md-4" style="margin-top:@mt;">
                    <div class="recent-card">
                        @if (!string.IsNullOrEmpty(p.PhotoPath))
                        {
                            <img src="@p.PhotoPath" style="width:100%; height:220px; object-fit:cover; border-radius:16px; margin-bottom:16px;" />
                        }
                        else
                        {
                            <div style="width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#FF5858,#F857A6); margin:0 auto 16px; display:flex; align-items:center; justify-content:center;">
                                <span style="color:white; font-size:28px; font-weight:700;">@(p.Name != null && p.Name.Length > 0 ? p.Name.Substring(0,1) : "?")</span>
                            </div>
