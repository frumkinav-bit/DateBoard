@page
@model IndexModel
@using DateBoard.Data
@inject ApplicationDbContext Db
@{
    ViewData["Title"] = "DateBoard";
    var profileCount = Db.Profiles.Count();
    var recentProfiles = Db.Profiles.OrderByDescending(p => p.CreatedAt).Take(3).ToList();
    var word = profileCount == 1 ? "пара подобрана" : (profileCount < 5 ? "пары подобраны" : "пар подобрано");
}

<style>
    @@keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(255,88,88,0.5); } 70% { box-shadow: 0 0 0 8px rgba(255,88,88,0); } 100% { box-shadow: 0 0 0 0 rgba(255,88,88,0); } }
    @@keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-14px); } }
    @@keyframes float2 { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-18px); } }
    @@keyframes float3 { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); } }
    @@keyframes float4 { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-12px); } }
    @@keyframes float5 { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-16px); } }
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes floatMobile { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); } }
    @@keyframes floatMobileSlow { 0%, 100% { transform: translateY(0px) rotate(0deg); } 50% { transform: translateY(-6px) rotate(2deg); } }
    @@keyframes pulseScale { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.03); } }
    .hero-animate { animation: fadeUp 0.8s ease forwards; }
    .hero-animate-delay { animation: fadeUp 0.8s ease 0.2s forwards; opacity: 0; }
    .hero-animate-delay2 { animation: fadeUp 0.8s ease 0.4s forwards; opacity: 0; }
    .float-card { animation: float 4s ease-in-out infinite; }
    .float-card-2 { animation: float2 5s ease-in-out 0.5s infinite; }
    .float-card-3 { animation: float3 3.5s ease-in-out 1s infinite; }
    .float-card-4 { animation: float4 4.5s ease-in-out 0.8s infinite; }
    .float-card-5 { animation: float5 3.8s ease-in-out 1.5s infinite; }
    .live-dot { width: 8px; height: 8px; border-radius: 50%; background: #FF5858; animation: pulse 2s infinite; display: inline-block; flex-shrink: 0; }
    .search-field-card { flex: 1; background: #F8F9FA; border-radius: 14px; padding: 14px 18px; cursor: pointer; transition: background 0.2s; }
    .search-field-card:hover { background: #F0F0F0; }
    .search-field-card p { margin: 0 0 4px; font-size: 10px; font-weight: 700; color: #FF5858; letter-spacing: 0.8px; }
    .search-field-card input { border: none !important; background: transparent !important; font-size: 14px !important; font-weight: 500 !important; color: #636E72 !important; padding: 0 !important; height: auto !important; width: 100% !important; outline: none !important; box-shadow: none !important; font-family: 'Montserrat', sans-serif !important; }
    .search-field-card input::placeholder { color: #B2BEC3; }
    .custom-dropdown { position: relative; }
    .custom-dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        left: -18px;
        right: -18px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 16px 48px rgba(255,88,88,0.15);
        z-index: 9999;
        overflow: hidden;
        border: 1px solid #FFE8E8;
    }
    .custom-dropdown-item {
        padding: 12px 18px;
        font-size: 14px;
        font-weight: 500;
        color: #636E72;
        cursor: pointer;
        transition: all 0.15s;
        font-family: 'Montserrat', sans-serif;
        border-bottom: 1px solid #FFF5F5;
    }
    .custom-dropdown-item:last-child { border-bottom: none; }
    .custom-dropdown-item:hover { background: rgba(255,88,88,0.05); color: #FF5858; }
    .custom-dropdown-item.selected { color: #FF5858; font-weight: 600; background: rgba(255,88,88,0.04); }
    .step-card-custom { padding: 40px 32px; border-radius: 24px; background: white; border: 1px solid #FFE8E8; box-shadow: 0 10px 30px rgba(255,88,88,0.06); transition: all 0.3s ease; text-align: center; position: relative; overflow: hidden; }
    .step-card-custom:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(255,88,88,0.14); border-color: #FF5858; }
    .step-card-active { border: 1.5px solid #FF5858 !important; box-shadow: 0 16px 40px rgba(255,88,88,0.14) !important; transform: translateY(-8px)!important; }
    .step-bg-num { position: absolute; font-size: 120px; font-weight: 700; color: rgba(255,88,88,0.1); bottom: -20px; right: -5px; line-height: 1; z-index: 0; pointer-events: none; }
    .step-content { position: relative; z-index: 1; }
    .recent-card { background: white; border-radius: 20px; padding: 24px 20px; text-align: center; box-shadow: 0 8px 24px rgba(255,88,166,0.08); border: 1px solid #EFEFEF; transition: all 0.3s ease; cursor: pointer; height: 100%; }
    .recent-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(255,88,88,0.15); border-color: #FFE0E0; }
    
    /* ===== МОБИЛЬНАЯ АДАПТАЦИЯ ===== */
    @@media (max-width: 991px) {
        .hero-section { padding: 30px 0 200px !important; position: relative; }
        .hero-section .container { padding-left: 20px; padding-right: 20px; }
        .hero-section h1 { font-size: 32px !important; line-height: 1.2 !important; }
        .hero-section p { font-size: 15px !important; }
        .hero-content { padding-right: 0 !important; }
        .search-fields { flex-direction: column !important; gap: 12px !important; }
        .search-field-card { width: 100%; padding: 16px 18px; min-height: 60px; }
        .search-box { max-width: 400px; margin: 0 auto; position: relative; z-index: 100; padding: 20px !important; }
        .floating-cards-container { display: none !important; }
        .mobile-cards-showcase { display: block !important; }
        .steps-section { margin-top: 0 !important; padding-top: 60px !important; }
        .steps-grid { grid-template-columns: 1fr !important; gap: 20px !important; }
        .step-card-custom { padding: 30px 24px; }
        .step-bg-num { font-size: 80px; }
        .quote-section h2 { font-size: 28px !important; }
        .quote-section { padding: 60px 0 !important; }
        .quote-section .container { padding-left: 20px; padding-right: 20px; }
        .stats-cards { margin-top: 40px; }
        .recent-cards-row { flex-direction: column; }
        .recent-cards-row .col-md-4 { margin-top: 20px !important; width: 100%; }
        .recent-card img { height: 180px !important; }
        .recent-section .container { padding-left: 20px; padding-right: 20px; }
        .steps-section .container { padding-left: 20px; padding-right: 20px; }
        /* Увеличенный отступ для мобильного меню */
        .hero-section { margin-bottom: 80px !important; }
    }
    
    @@media (max-width: 768px) {
        .hero-section { padding-bottom: 220px !important; margin-bottom: 100px !important; }
        .hero-section h1 { font-size: 28px !important; }
        .search-box { padding: 18px !important; }
        .search-field-card { min-height: 65px; }
        .stats-cards { flex-direction: column; }
        .mobile-main-card { transform: scale(0.9); }
    }
    
    @@media (min-width: 992px) {
        .floating-cards-container { display: block; }
        .mobile-cards-showcase { display: none !important; }
    }
    
    /* Мобильная композиция с центральной карточкой */
    .mobile-cards-showcase {
        display: none;
        position: relative;
        height: 220px;
        margin: 20px auto 40px;
        max-width: 340px;
    }
    
    /* Центральная карточка Анна - увеличенная и повыше */
    .mobile-main-card {
        position: absolute;
        top: 0%;
        left: 28%;
        transform: translateX(-50%);
        background: white;
        border-radius: 24px;
        padding: 14px;
        width: 150px;
        box-shadow: 0 20px 50px rgba(255,88,88,0.2);
        z-index: 10;
        animation: floatMobile 4s ease-in-out infinite;
        text-align: center;
    }
    
    .mobile-main-avatar {
        width: 50px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg,#FF5858,#F857A6);
        margin: 0 auto 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 22px;
        box-shadow: 0 8px 20px rgba(255,88,88,0.3);
    }
    
    .mobile-main-card h4 {
        margin: 0 0 3px;
        font-size: 15px;
        font-weight: 700;
        color: #2D3436;
    }
    
    .mobile-main-card p {
        margin: 0 0 6px;
        font-size: 10px;
        color: #636E72;
    }
    
    /* Метка Сваха в мобильной версии */
    .mobile-svah-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 9px;
        font-weight: 600;
        color: #FF5858;
        background: rgba(255,88,88,0.08);
        padding: 2px 6px;
        border-radius: 12px;
        margin-bottom: 4px;
    }
    
    .mobile-match-percent {
        font-size: 11px;
        font-weight: 700;
        color: #F857A6;
        margin-bottom: 8px;
    }
    
    .mobile-main-badge {
        background: linear-gradient(135deg,#FF5858,#F857A6);
        border-radius: 20px;
        padding: 5px 10px;
        font-size: 10px;
        color: white;
        font-weight: 600;
    }
    
    /* Спутники вокруг центральной карточки */
    .mobile-satellite {
        position: absolute;
        border-radius: 50px;
        padding: 8px 14px;
        font-size: 12px;
        font-weight: 600;
        box-shadow: 0 4px 16px rgba(255,88,88,0.15);
        animation: floatMobileSlow 3s ease-in-out infinite;
        white-space: nowrap;
    }
    
    .mobile-satellite-blur {
        filter: blur(1px);
        opacity: 0.7;
    }
    
    .mobile-satellite-blur-more {
        filter: blur(2px);
        opacity: 0.5;
    }
    
    .mobile-satellite-white {
        background: white;
        color: #2D3436;
        border: 1px solid rgba(255,88,88,0.1);
    }
    
    .mobile-satellite-gradient {
        background: linear-gradient(135deg,#FF5858,#F857A6);
        color: white;
    }
    
    .mobile-satellite-light {
        background: rgba(255,88,88,0.08);
        color: #FF5858;
    }
    
    .mobile-satellite-icon {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    
    /* Позиции спутников - скорректированы для увеличенной карточки */
    .satellite-1 { top: 5%; right: 0; animation-delay: 0s; }
    .satellite-2 { top: 35%; right: -5%; animation-delay: 0.5s; }
    .satellite-3 { bottom: 15%; left: 0; animation-delay: 1s; }
    .satellite-4 { bottom: 0%; right: 5%; animation-delay: 1.5s; }
    .satellite-5 { top: 45%; left: 45%; animation-delay: 0.3s; z-index: 5; }
    .satellite-6 { top: 15%; left: 0; animation-delay: 0.8s; }
    .satellite-7 { top: 0%; left: 5%; animation-delay: 1.2s; }
    
    /* Декоративные круги как в веб версии */
    .mobile-deco-circle {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }
    
    .mobile-deco-1 {
        width: 100px;
        height: 100px;
        background: rgba(255,88,88,0.05);
        top: 10%;
        right: 20%;
    }
    
    .mobile-deco-2 {
        width: 60px;
        height: 60px;
        background: rgba(248,87,166,0.06);
        bottom: 20%;
        left: 30%;
    }
    
    .mobile-deco-3 {
        width: 40px;
        height: 40px;
        background: rgba(255,88,88,0.08);
        top: 40%;
        left: 10%;
    }
    
    /* Метка выбора сваха */
    .svah-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #FF5858;
        background: rgba(255,88,88,0.08);
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 8px;
    }
    
    /* Совпадение процент */
    .match-percent {
        font-size: 13px;
        font-weight: 700;
        color: #F857A6;
        margin-top: 8px;
    }
    
    /* Одобрено */
    .approved-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 600;
        color: #00B894;
        background: rgba(0,184,148,0.08);
        padding: 6px 14px;
        border-radius: 20px;
    }
    
    .approved-badge svg {
        width: 14px;
        height: 14px;
    }

    /* Мобильная иконка свах одобрил */
    .mobile-approved-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 9px;
        font-weight: 600;
        color: #00B894;
        background: rgba(0,184,148,0.08);
        padding: 2px 6px;
        border-radius: 12px;
        margin-bottom: 4px;
    }

    .mobile-approved-badge svg {
        width: 10px;
        height: 10px;
    }
</style>

<!-- Hero -->
<div class="hero-section" style="background: white; padding: 50px 0 100px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -120px; left: -120px; width: 500px; height: 500px; border-radius: 50%; background: #FF5858; filter: blur(120px); opacity: 0.05; pointer-events: none;"></div>
    <div style="position: absolute; bottom: -120px; right: -120px; width: 500px; height: 500px; border-radius: 50%; background: #F857A6; filter: blur(120px); opacity: 0.05; pointer-events: none;"></div>

    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-content" style="padding-left: 0; padding-right: 60px; position: relative; z-index: 10;">

                <div class="hero-animate" style="display: inline-flex; align-items: center; gap: 8px; background: rgba(255,88,88,0.06); border: 1px solid rgba(255,88,88,0.15); border-radius: 50px; padding: 8px 18px; margin-bottom: 28px; margin-left: 20px;">
                    <div class="live-dot"></div>
                    <span style="font-size: 13px; color: #FF5858; font-weight: 600;"><span id="counter">0</span> @word</span>
                </div>

                <h1 class="hero-animate-delay" style="font-size: 48px; font-weight: 700; color: #2D3436; line-height: 1.15; margin-bottom: 20px; letter-spacing: -1px; padding-left: 20px;">
                    Свах Купидонов уже подобрал тебе 
                    <span style="background: linear-gradient(135deg, #FF5858, #F857A6); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">пару</span>
                </h1>

                <p class="hero-animate-delay2" style="color: #636E72; font-size: 17px; line-height: 1.8; margin-bottom: 36px; padding-left: 20px;">
                    Это не случайность. Свах не ошибается.
                </p>

                <!-- Мобильная композиция: центральная карточка + спутники -->
                <div class="mobile-cards-showcase">
                    <!-- Декоративные круги -->
                    <div class="mobile-deco-circle mobile-deco-1"></div>
                    <div class="mobile-deco-circle mobile-deco-2"></div>
                    <div class="mobile-deco-circle mobile-deco-3"></div>
                    
                    <!-- Спутники - размытые и полупрозрачные -->
                    <div class="mobile-satellite mobile-satellite-white mobile-satellite-blur satellite-1">
                        <span>+12 сегодня</span>
                    </div>
                    
                    <div class="mobile-satellite mobile-satellite-light mobile-satellite-blur satellite-2">
                        <span class="mobile-satellite-icon">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="#FF5858"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                            3 новых
                        </span>
                    </div>
                    
                    <!-- Дима - непрозрачный, слева -->
                    <div class="mobile-satellite mobile-satellite-white satellite-3">
                        <span>Дима, 31</span>
                    </div>
                    
                    <div class="mobile-satellite mobile-satellite-gradient satellite-4">
                        <span class="mobile-satellite-icon">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                            24/7
                        </span>
                    </div>
                    
                    <div class="mobile-satellite mobile-satellite-white mobile-satellite-blur-more satellite-5">
                        <span>Москва</span>
                    </div>
                    
                    <div class="mobile-satellite mobile-satellite-light satellite-6">
                        <span>Игорь, 28</span>
                    </div>
                    
                    <!-- Новый элемент в левом верхнем углу -->
                    <div class="mobile-satellite mobile-satellite-light mobile-satellite-blur-more satellite-7" style="padding: 6px 10px; font-size: 10px;">
                        <span class="mobile-satellite-icon">
                            <div class="live-dot" style="width: 6px; height: 6px;"></div>
                            онлайн
                        </span>
                    </div>
                    
                    <!-- Центральная карточка Анна - увеличенная -->
                    <div class="mobile-main-card">
                        <div class="mobile-main-avatar">А</div>
                        
                        <!-- Метка Сваха -->
                        <div class="mobile-svah-badge">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="#FF5858"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                            Выбор Сваха
                        </div>

                        <!-- Метка Свах одобрил -->
                        <div class="mobile-approved-badge">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Свах одобрил
                        </div>
                        
                        <h4>Анна, 24</h4>
                        <p>Москва · Отношения</p>
                        
                        <!-- Совпадение -->
                        <div class="mobile-match-percent">Совпадение: 94%</div>
                        
                        <div class="mobile-main-badge">Интересно…</div>
                    </div>
                </div>

                <div class="hero-animate-delay2">
                    <form method="get" action="/Feed/Index">
                        <div class="search-box" style="background: white; border-radius: 24px; border: 1px solid #F0F0F0; box-shadow: 0 12px 40px rgba(255,88,88,0.08); padding: 22px;">
                            <p style="margin: 0 0 14px; font-size: 14px; font-weight: 600; color: #2D3436;">Найди людей рядом</p>
                            <div class="search-fields" style="display: flex; gap: 10px; margin-bottom: 14px;">

                                <div class="search-field-card">
                                    <p>ГОРОД</p>
                                    <input type="text" name="city" placeholder="Москва, Питер..." />
                                </div>

                                <div class="search-field-card" id="goalWrapper">
                                    <p>ЦЕЛЬ</p>
                                    <input type="hidden" name="goal" id="goalValue" value="" />
                                    <div class="custom-dropdown" id="goalDropdown">
                                        <div onclick="toggleGoal(event)" style="display:flex; align-items:center; justify-content:space-between; cursor:pointer; height:22px;">
                                            <span id="goalLabel" style="font-size:14px; font-weight:500; color:#B2BEC3;">Любая</span>
                                            <svg id="goalArrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF5858" stroke-width="2.5" style="flex-shrink:0; transition:transform 0.2s;">
                                                <polyline points="6 9 12 15 18 9"></polyline></svg>
                                        </div>
                                        <div class="custom-dropdown-menu" id="goalMenu">
                                            <div class="custom-dropdown-item selected" onclick="chooseGoal('', 'Любая', this)">Любая</div>
                                            <div class="custom-dropdown-item" onclick="chooseGoal('Дружба', 'Дружба', this)">Дружба</div>
                                            <div class="custom-dropdown-item" onclick="chooseGoal('Отношения', 'Отношения', this)">Отношения</div>
                                            <div class="custom-dropdown-item" onclick="chooseGoal('Брак', 'Брак', this)">Брак</div>
                                            <div class="custom-dropdown-item" onclick="chooseGoal('Общение', 'Общение', this)">Общение</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" style="width:100%; background:linear-gradient(135deg,#FF5858,#F857A6); border:none; border-radius:50px; padding:16px; color:white; font-weight:600; font-size:15px; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:10px; box-shadow:0 8px 24px rgba(255,88,88,0.3); transition:all 0.3s ease; font-family:'Montserrat',sans-serif;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                                Подобрать для меня
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Десктоп: плавающие карточки профилей -->
            <div class="col-lg-6 floating-cards-container" style="position: relative; height: 580px;">
                <div style="position:absolute; width:360px; height:360px; border-radius:50%; background:linear-gradient(135deg,rgba(255,88,88,0.07),rgba(248,87,166,0.1)); top:50%; left:50%; transform:translate(-42%,-50%); z-index:0;"></div>
                <div style="position:absolute; width:160px; height:160px; border-radius:50%; background:rgba(255,88,88,0.04); top:5%; right:8%; z-index:0;"></div>
                <div style="position:absolute; width:80px; height:80px; border-radius:50%; background:rgba(248,87,166,0.06); bottom:10%; left:8%; z-index:0;"></div>

                <!-- Главная карточка Анна - увеличенная и повыше -->
                <div class="float-card" style="position:absolute; background:white; border-radius:24px; padding:28px; width:220px; box-shadow:0 20px 60px rgba(255,88,88,0.18); z-index:3; top:22%; left:35%; transform:translate(-50%,-50%);">
                    <div style="width:72px; height:72px; border-radius:50%; background:linear-gradient(135deg,#FF5858,#F857A6); margin:0 auto 16px; display:flex; align-items:center; justify-content:center;">
                        <span style="color:white; font-size:28px; font-weight:700;">А</span>
                    </div>
                    
                    <!-- Метка Сваха -->
