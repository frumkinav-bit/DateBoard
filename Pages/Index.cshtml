                        <h5 style="font-size:17px; font-weight:700; color:#2D3436; margin-bottom:6px;">@p.Name, @p.Age</h5>
                        <p style="font-size:13px; color:#636E72; margin-bottom:10px;">@p.City</p>
                        <span style="display:inline-block; background:rgba(255,88,88,0.07); border-radius:20px; padding:5px 16px; font-size:12px; color:#FF5858; font-weight:600;">@p.Goal</span>
