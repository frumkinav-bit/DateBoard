<script>
    document.addEventListener('DOMContentLoaded', function () {
        var target = @profileCount;
        var el = document.getElementById('counter');
        if (el) {
            if (target === 0) { el.textContent = 0; }
            else {
                var current = 0;
                var step = Math.max(1, Math.ceil(target / 30));
                var timer = setInterval(function () {
                    current = Math.min(current + step, target);
                    el.textContent = current;
                    if (current >= target) clearInterval(timer);
                }, 50);
            }
        }

        document.addEventListener('click', function (e) {
            var menu = document.getElementById('goalMenu');
            var arrow = document.getElementById('goalArrow');
            if (menu && !e.target.closest('#goalDropdown')) {
                menu.style.display = 'none';
                if (arrow) arrow.style.transform = 'rotate(0deg)';
            }
        });
    });

    function toggleGoal(e) {
        e.stopPropagation();
        var menu = document.getElementById('goalMenu');
        var arrow = document.getElementById('goalArrow');
        var isOpen = menu.style.display === 'block';
        menu.style.display = isOpen ? 'none' : 'block';
        arrow.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
    }

    function chooseGoal(value, label, el) {
        document.getElementById('goalValue').value = value;
        document.getElementById('goalLabel').textContent = label;
        document.getElementById('goalLabel').style.color = value ? '#636E72' : '#B2BEC3';
        document.getElementById('goalMenu').style.display = 'none';
        document.getElementById('goalArrow').style.transform = 'rotate(0deg)';
        document.querySelectorAll('.custom-dropdown-item').forEach(function (i) {
            i.classList.remove('selected');
        });
        el.classList.add('selected');
    }
</script>