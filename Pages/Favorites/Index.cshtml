@page
@model DateBoard.Pages.Favorites.IndexModel
@using DateBoard.Models
@{
    ViewData["Title"] = "Избранное";
}
 
<style>
    .fav-card {
        background: var(--card-bg);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 24px var(--shadow);
        border: 1px solid var(--border);
        transition: all 0.3s ease;
        height: 100%;
        position: relative;
    }
    .fav-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 48px var(--shadow-hover);
        border-color: var(--accent);
    }
    .fav-card-img {
        width: 100%;
        height: 260px;
        object-fit: cover;
    }
    .fav-card-no-photo {
        height: 260px;
        background: linear-gradient(135deg, var(--hover-bg), var(--hover-bg));
        opacity: 0.8;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 12px;
    }
    .fav-card-body { padding: 20px; }
    .fav-tag {
        display: inline-block;
        background: var(--hover-bg);
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 12px;
        color: var(--accent);
        font-weight: 600;
    }
    .fav-tag-secondary {
        display: inline-block;
        background: var(--bg);
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 500;
    }
    .delete-btn {
        width: 100%;
        background: var(--card-bg);
        border: 1.5px solid var(--border);
        border-radius: 50px;
        padding: 10px;
        color: var(--accent);
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s ease;
        font-family: 'Montserrat', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }
    .delete-btn:hover {
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 16px var(--shadow-hover);
    }
    .heart-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--card-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px var(--shadow-hover);
        z-index: 2;
    }
    .heart-badge svg {
        fill: var(--accent);
    }
</style>
 
<!-- Шапка -->
<div style="background: var(--card-bg); border-bottom: 1px solid var(--border); padding: 24px 0; margin-bottom: 0;">
    <div class="container">
        <div style="display:flex; align-items:center; justify-content:space-between;">
            <div>
                <p style="font-size:12px; letter-spacing:2px; color:var(--accent2); font-weight:600; margin-bottom:6px;">МОИ СИМПАТИИ</p>
                <h1 style="font-size:28px; font-weight:700; color:var(--text-main); margin:0;">Избранное</h1>
            </div>
            @if (Model.Favorites.Any())
            {
                <div style="display:flex; align-items:center; gap:8px; background:var(--hover-bg); border:1px solid var(--border); border-radius:50px; padding:8px 16px;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--accent)"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    <span style="font-size:13px; color:var(--accent); font-weight:600;">@Model.Favorites.Count() анкет</span>
                </div>
            }
        </div>
    </div>
</div>
 
<!-- Контент -->
<div style="background: var(--bg); padding: 40px 0 60px; min-height: calc(100vh - 130px);">
    <div class="container">
 
        @if (!Model.Favorites.Any())
        {
            <!-- Пустое состояние -->
            <div style="text-align:center; padding:80px 0;">
                <div style="width:100px; height:100px; border-radius:50%; background:var(--hover-bg); margin:0 auto 24px; display:flex; align-items:center; justify-content:center;">
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                </div>
                <h3 style="font-size:22px; font-weight:700; color:var(--text-main); margin-bottom:10px;">Пока здесь пусто</h3>
                <p style="color:var(--text-muted); font-size:15px; margin-bottom:28px; line-height:1.6; opacity:0.8;">Добавляй понравившихся людей в избранное<br>и они появятся здесь</p>
                <a href="/Feed/Index" style="background:linear-gradient(135deg,var(--accent),var(--accent2)); color:white; border-radius:50px; padding:14px 36px; font-weight:600; font-size:14px; text-decoration:none; display:inline-flex; align-items:center; gap:8px; box-shadow:0 8px 24px var(--shadow-hover); transition:all 0.2s;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <span style="color:white !important;">Перейти в ленту</span>
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var fav in Model.Favorites)
                {
                    <div class="col-md-4 col-lg-3">
                        <div class="fav-card">
 
                            <!-- Сердечко -->
                            <div class="heart-badge">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--accent)"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                            </div>
 
                            @if (!string.IsNullOrEmpty(fav.Profile?.PhotoPath))
                            {
                                <img src="@fav.Profile.PhotoPath" class="fav-card-img" />
                            }
                            else
                            {
                                <div class="fav-card-no-photo">
                                    <div style="width:72px; height:72px; border-radius:50%; background:linear-gradient(135deg,var(--accent),var(--accent2)); display:flex; align-items:center; justify-content:center; box-shadow:0 8px 24px var(--shadow-hover);">
                                        <span style="color:white; font-size:28px; font-weight:700;">@(fav.Profile?.Name != null && fav.Profile.Name.Length > 0 ? fav.Profile.Name.Substring(0,1) : "?")</span>
                                    </div>
                                    <span style="font-size:12px; color:var(--text-muted); font-weight:500; opacity:0.7;">Нет фото</span>
                                </div>
                            }
 
                            <div class="fav-card-body">
                                <h5 style="font-size:18px; font-weight:700; color:var(--text-main); margin:0 0 6px;">@fav.Profile?.Name, @fav.Profile?.Age</h5>
 
                                <p style="font-size:13px; color:var(--text-muted); margin-bottom:12px; display:flex; align-items:center; gap:4px; opacity:0.8;">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                    @fav.Profile?.City
                                </p>
 
                                <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:16px;">
                                    @if (!string.IsNullOrEmpty(fav.Profile?.Goal))
                                    {
                                        <span class="fav-tag">@fav.Profile.Goal</span>
                                    }
                                    @if (!string.IsNullOrEmpty(fav.Profile?.About))
                                    {
                                        <span class="fav-tag-secondary" style="max-width:120px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@fav.Profile.About</span>
                                    }
                                </div>
 
                                @if (!string.IsNullOrEmpty(fav.Profile?.Hobbies))
                                {
                                    <p style="font-size:12px; color:var(--text-muted); margin-bottom:14px; display:flex; align-items:center; gap:4px; opacity:0.7;">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--accent2)"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                        @fav.Profile.Hobbies
                                    </p>
                                }
 
                                <form method="post">
                                    <input type="hidden" name="favoriteId" value="@fav.Id" />
                                    <button type="submit" class="delete-btn">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path></svg>
                                        Удалить из избранного
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>