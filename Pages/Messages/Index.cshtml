@page
@model DateBoard.Pages.Messages.IndexModel
@{
    ViewData["Title"] = "Сообщения";
}
 
<style>
    .dialog-item {
        display: flex; align-items: center; gap: 14px;
        padding: 16px 20px; background: white;
        border-radius: 16px; margin-bottom: 10px;
        border: 1px solid #EFEFEF;
        transition: all 0.2s; cursor: pointer;
        text-decoration: none;
    }
    .dialog-item:hover {
        border-color: #FFE0E0;
        box-shadow: 0 4px 16px rgba(255,88,88,0.08);
        transform: translateY(-2px);
    }
    .dialog-avatar {
        width: 54px; height: 54px; border-radius: 50%;
        object-fit: cover; flex-shrink: 0;
    }
    .dialog-avatar-placeholder {
        width: 54px; height: 54px; border-radius: 50%;
        background: linear-gradient(135deg, #FF5858, #F857A6);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .unread-badge {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        color: white; border-radius: 50%;
        width: 22px; height: 22px;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700; flex-shrink: 0;
    }
</style>
 
<div style="background: #F8F9FA; min-height: 100vh;">
    <div style="background: white; border-bottom: 1px solid #EFEFEF; padding: 24px 0;">
        <div class="container" style="max-width: 700px;">
            <p style="font-size:12px; letter-spacing:2px; color:#F857A6; font-weight:600; margin-bottom:6px;">ЛИЧНЫЕ</p>
            <h1 style="font-size:28px; font-weight:700; color:#2D3436; margin:0;">Сообщения</h1>
        </div>
    </div>
 
    <div class="container" style="max-width: 700px; padding-top: 24px; padding-bottom: 60px;">
        @if (!Model.Dialogs.Any())
        {
            <div style="text-align:center; padding:80px 0;">
                <div style="width:90px; height:90px; border-radius:50%; background:rgba(255,88,88,0.08); margin:0 auto 20px; display:flex; align-items:center; justify-content:center;">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF5858" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                </div>
                <h3 style="font-size:20px; font-weight:700; color:#2D3436; margin-bottom:8px;">Нет сообщений</h3>
                <p style="color:#B2BEC3; margin-bottom:24px;">Напиши кому-нибудь первым!</p>
                <a href="/Feed/Index" style="background:linear-gradient(135deg,#FF5858,#F857A6); color:white !important; border-radius:50px; padding:14px 32px; font-weight:600; font-size:14px; text-decoration:none; box-shadow:0 8px 24px rgba(255,88,88,0.3);">
                    Найти людей
                </a>
            </div>
        }
        else
        {
            @foreach (var dialog in Model.Dialogs)
            {
                <a href="/Messages/Dialog/@dialog.UserId" class="dialog-item">
                    @if (!string.IsNullOrEmpty(dialog.PhotoPath))
                    {
                        <img src="@dialog.PhotoPath" class="dialog-avatar" />
                    }
                    else
                    {
                        <div class="dialog-avatar-placeholder">
                            <span style="color:white; font-size:20px; font-weight:700;">@dialog.Name.Substring(0, 1).ToUpper()</span>
                        </div>
                    }
                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:4px;">
                            <p style="font-size:15px; font-weight:700; color:#2D3436; margin:0;">@dialog.Name</p>
                            <span style="font-size:11px; color:#B2BEC3;">@dialog.LastMessageTime.ToString("dd.MM HH:mm")</span>
                        </div>
                        <p style="font-size:13px; color:#B2BEC3; margin:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@dialog.LastMessage</p>
                    </div>
                    @if (dialog.UnreadCount > 0)
                    {
                        <div class="unread-badge">@dialog.UnreadCount</div>
                    }
                </a>
            }
        }
    </div>
</div>