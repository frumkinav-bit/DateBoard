@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}
 
<style>
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #FFF5F7 0%, #F8F9FA 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }
    .auth-card {
        background: white;
        border-radius: 28px;
        padding: 40px;
        width: 100%;
        max-width: 440px;
        box-shadow: 0 20px 60px rgba(255,88,88,0.1);
        border: 1px solid #FFE8E8;
    }
    .auth-logo {
        text-align: center;
        margin-bottom: 28px;
    }
    .auth-logo-text {
        font-size: 28px;
        font-weight: 800;
        color: #2D3436;
        letter-spacing: -0.5px;
    }
    .auth-logo-text span {
        background: linear-gradient(135deg, #FF5858, #F857A6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .auth-title {
        font-size: 22px;
        font-weight: 700;
        color: #2D3436;
        margin-bottom: 6px;
        text-align: center;
    }
    .auth-subtitle {
        font-size: 14px;
        color: #B2BEC3;
        text-align: center;
        margin-bottom: 28px;
    }
    .auth-field {
        background: #F8F9FA;
        border-radius: 14px;
        padding: 14px 18px;
        margin-bottom: 12px;
        border: 1.5px solid transparent;
        transition: all 0.2s;
    }
    .auth-field:focus-within {
        border-color: #FF5858;
        background: white;
        box-shadow: 0 4px 16px rgba(255,88,88,0.08);
    }
    .auth-field label {
        display: block;
        font-size: 10px;
        font-weight: 700;
        color: #FF5858;
        letter-spacing: 0.8px;
        margin-bottom: 4px;
        text-transform: uppercase;
    }
    .auth-field input {
        border: none !important;
        background: transparent !important;
        font-size: 14px !important;
        font-weight: 500 !important;
        color: #2D3436 !important;
        padding: 0 !important;
        height: auto !important;
        width: 100% !important;
        outline: none !important;
        box-shadow: none !important;
        font-family: 'Montserrat', sans-serif !important;
    }
    .auth-field input::placeholder { color: #B2BEC3; }
    .auth-submit {
        width: 100%;
        background: linear-gradient(135deg, #FF5858, #F857A6);
        border: none;
        border-radius: 50px;
        padding: 16px;
        color: white;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        font-family: 'Montserrat', sans-serif;
        box-shadow: 0 8px 24px rgba(255,88,88,0.3);
        transition: all 0.2s;
        margin-top: 8px;
    }
    .auth-submit:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(255,88,88,0.4); }
    .auth-terms {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 16px;
        padding: 14px 16px;
        background: rgba(255,88,88,0.04);
        border-radius: 12px;
        border: 1px solid rgba(255,88,88,0.1);
    }
    .auth-terms input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: #FF5858;
        flex-shrink: 0;
        margin-top: 1px;
        cursor: pointer;
    }
    .auth-terms label {
        font-size: 13px;
        color: #636E72;
        line-height: 1.5;
        cursor: pointer;
    }
    .auth-terms a { color: #FF5858 !important; font-weight: 600; }
    .auth-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 20px 0;
    }
    .auth-divider-line { flex: 1; height: 1px; background: #EFEFEF; }
    .auth-divider-text { font-size: 12px; color: #B2BEC3; font-weight: 500; white-space: nowrap; }
    .auth-login-link {
        text-align: center;
        font-size: 14px;
        color: #636E72;
    }
    .auth-login-link a { color: #FF5858 !important; font-weight: 600; }
    .validation-error {
        background: rgba(255,88,88,0.06);
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 16px;
        border: 1px solid rgba(255,88,88,0.15);
    }
    .validation-error span { font-size: 13px; color: #FF5858; }
    .field-error { font-size: 11px; color: #FF5858; margin-top: 4px; padding: 0 4px; }
    .auth-perks {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }
    .perk-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: #636E72;
        font-weight: 500;
    }
    .perk-icon {
        width: 24px; height: 24px; border-radius: 50%;
        background: rgba(255,88,88,0.08);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
</style>
 
<div class="auth-page">
    <div class="auth-card">
 
        <!-- Логотип -->
        <div class="auth-logo">
            <div class="auth-logo-text">Date<span>Board</span></div>
        </div>
 
        <h1 class="auth-title">Создать аккаунт</h1>
        <p class="auth-subtitle">Найди своего человека уже сегодня</p>
 
        <!-- Преимущества -->
        <div class="auth-perks">
            <div class="perk-item">
                <div class="perk-icon">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FF5858" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                </div>
                Бесплатно
            </div>
            <div class="perk-item">
                <div class="perk-icon">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FF5858" stroke-width="2.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                Реальные люди
            </div>
            <div class="perk-item">
                <div class="perk-icon">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FF5858" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                </div>
                Безопасно
            </div>
        </div>
 
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
 
            <div asp-validation-summary="ModelOnly" class="validation-error" style="display:none;">
                <span></span>
            </div>
 
            <div class="auth-field">
                <label asp-for="Input.Email">EMAIL</label>
                <input asp-for="Input.Email" autocomplete="username" placeholder="example@mail.ru" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>
 
            <div class="auth-field">
                <label asp-for="Input.Password">ПАРОЛЬ</label>
                <input asp-for="Input.Password" autocomplete="new-password" placeholder="Минимум 6 символов" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>
 
            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword">ПОВТОРИТЕ ПАРОЛЬ</label>
                <input asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="Повторите пароль" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
            </div>
 
            <div class="auth-terms">
                <input type="checkbox" id="agreeTerms" name="agreeTerms" required />
                <label for="agreeTerms">
                    Я принимаю <a href="/Terms" target="_blank">правила сайта</a> и соглашаюсь с политикой конфиденциальности
                </label>
            </div>
 
            <button id="registerSubmit" type="submit" class="auth-submit">
                Создать аккаунт
            </button>
        </form>
 
        <div class="auth-divider">
            <div class="auth-divider-line"></div>
            <div class="auth-divider-text">уже есть аккаунт?</div>
            <div class="auth-divider-line"></div>
        </div>
 
        <div class="auth-login-link">
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Войти в DateBoard</a>
        </div>
 
    </div>
</div>
 
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var summary = document.querySelector('[data-valmsg-summary]');
        if (summary && summary.querySelector('li')) {
            summary.closest('.validation-error').style.display = 'block';
        }
    </script>
}
 