@page
@model LoginModel
@{
    ViewData["Title"] = "Вход";
}
 
<style>
    .auth-page { min-height: 100vh; background: linear-gradient(135deg, var(--hover-bg) 0%, var(--bg) 100%); display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
    .auth-card { background: var(--card-bg); border-radius: 28px; padding: 40px; width: 100%; max-width: 440px; box-shadow: 0 20px 60px var(--shadow-hover); border: 1px solid var(--border); }
    .auth-logo { text-align: center; margin-bottom: 28px; }
    .auth-field { background: var(--bg); border-radius: 14px; padding: 14px 18px; margin-bottom: 12px; border: 1.5px solid transparent; transition: all 0.2s; }
    .auth-field:focus-within { border-color: var(--accent); background: var(--card-bg); box-shadow: 0 4px 16px var(--shadow-hover); }
    .auth-field label { display: block; font-size: 10px; font-weight: 700; color: var(--accent); letter-spacing: 0.8px; margin-bottom: 4px; text-transform: uppercase; }
    .auth-field input { border: none !important; background: transparent !important; font-size: 14px !important; font-weight: 500 !important; color: var(--text-main) !important; padding: 0 !important; height: auto !important; width: 100% !important; outline: none !important; box-shadow: none !important; font-family: 'Montserrat', sans-serif !important; }
    .auth-field input::placeholder { color: var(--text-muted); opacity: 0.6; }
    .auth-submit { width: 100%; background: linear-gradient(135deg, var(--accent), var(--accent2)); border: none; border-radius: 50px; padding: 16px; color: white; font-weight: 700; font-size: 15px; cursor: pointer; font-family: 'Montserrat', sans-serif; box-shadow: 0 8px 24px var(--shadow-hover); transition: all 0.2s; margin-top: 8px; }
    .auth-submit:hover { transform: translateY(-2px); box-shadow: 0 12px 32px var(--shadow-hover); }
    .auth-remember { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; padding: 12px 16px; background: var(--bg); border-radius: 12px; }
    .auth-remember input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; }
    .auth-remember label { font-size: 13px; color: var(--text-muted); cursor: pointer; margin: 0; }
    .auth-links { display: flex; flex-direction: column; gap: 8px; margin-top: 16px; text-align: center; }
    .auth-links a { font-size: 13px; color: var(--text-muted) !important; text-decoration: none; transition: color 0.2s; opacity: 0.8; }
    .auth-links a:hover { color: var(--accent) !important; opacity: 1; }
    .auth-divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
    .auth-divider-line { flex: 1; height: 1px; background: var(--border); }
    .auth-divider-text { font-size: 12px; color: var(--text-muted); font-weight: 500; opacity: 0.7; }
    .field-error { font-size: 11px; color: var(--accent); margin-top: 4px; padding: 0 2px; }
    .svah-tagline { font-size: 13px; color: var(--accent); text-align: center; margin-bottom: 20px; font-style: italic; }
</style>
 
<div class="auth-page">
    <div class="auth-card">
 
        <div class="auth-logo">
            <div style="font-size:28px; font-weight:800; color:var(--text-main); letter-spacing:-0.5px;">
                Свах <span style="background:linear-gradient(135deg,var(--accent),var(--accent2)); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Купидонов</span>
            </div>
        </div>

        <p class="svah-tagline">«Не переживай. Я разберусь»</p>
 
        <h1 style="font-size:22px; font-weight:700; color:var(--text-main); margin-bottom:6px; text-align:center;">С возвращением!</h1>
        <p style="font-size:14px; color:var(--text-muted); text-align:center; margin-bottom:28px; opacity:0.8;">Я уже начал подбирать</p>
 
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" style="background:var(--hover-bg); border-radius:12px; padding:12px 16px; margin-bottom:16px; font-size:13px; color:var(--accent);"></div>
 
            <div class="auth-field">
                <label asp-for="Input.Email">EMAIL</label>
                <input asp-for="Input.Email" autocomplete="username" placeholder="example@mail.ru" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>
 
            <div class="auth-field">
                <label asp-for="Input.Password">ПАРОЛЬ</label>
                <input asp-for="Input.Password" autocomplete="current-password" placeholder="Введи пароль" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>
 
            <div class="auth-remember">
                <input asp-for="Input.RememberMe" type="checkbox" id="rememberMe" />
                <label for="rememberMe">Запомнить меня</label>
            </div>
 
            <button id="login-submit" type="submit" class="auth-submit">Я начинаю</button>
        </form>
 
        <div class="auth-links">
            <a asp-page="./ForgotPassword">Забыли пароль?</a>
            <a asp-page="./ResendEmailConfirmation">Отправить подтверждение повторно</a>
        </div>
 
        <div class="auth-divider">
            <div class="auth-divider-line"></div>
            <div class="auth-divider-text">новенький?</div>
            <div class="auth-divider-line"></div>
        </div>
 
        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
               style="display:flex; align-items:center; justify-content:center; gap:8px; width:100%; background:var(--card-bg); border:1.5px solid var(--border); border-radius:50px; padding:14px; color:var(--accent) !important; font-weight:700; font-size:14px; text-decoration:none; transition:all 0.2s;"
               onmouseover="this.style.borderColor='var(--accent)'; this.style.background='var(--hover-bg)'"
               onmouseout="this.style.borderColor='var(--border)'; this.style.background='var(--card-bg)'">
            Посмотрим, кто тебе подходит…
        </a>
    </div>
</div>
 
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}